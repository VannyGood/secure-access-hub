# Copy to .env and adjust

# Database
# For Vercel (serverless) you MUST use a hosted database (Postgres recommended).
# Free options: Neon, Supabase, Railway.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"

JWT_SECRET="change-me-in-production"
PORT=3000

# Marzban panel API (no trailing slash). Default Docker/API port is often 8000 or 62050 — use yours.
MARZBAN_URL="http://localhost:8000"
MARZBAN_USERNAME="admin"
MARZBAN_PASSWORD="admin"

# Set to "true" to skip Marzban (mock subscription URLs only). Omit or "false" to use real API.
MOCK_MARZBAN=

# Browser-only: fake Telegram user id for local testing (optional). Or open http://localhost:8080/?tg=123456789
VITE_DEV_TELEGRAM_ID=123456789

# Production (Vercel): URL of your deployed Express API — no trailing slash. Leave empty when using same-origin /api (local dev proxy or vercel.json rewrite).
# VITE_API_URL=https://your-backend.example.com
